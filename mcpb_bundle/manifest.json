{
  "manifest_version": "0.3",
  "name": "poe2-mcp",
  "version": "1.0.0",
  "description": "AI-powered Path of Exile 2 build optimization MCP server. Community project - not affiliated with Grinding Gear Games.",
  "author": {
    "name": "HivemindOverlord",
    "url": "https://github.com/HivemindOverlord/poe2-mcp"
  },
  "license": "MIT",
  "homepage": "https://github.com/HivemindOverlord/poe2-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/HivemindOverlord/poe2-mcp.git"
  },
  "keywords": [
    "path-of-exile",
    "poe2",
    "build-optimizer",
    "gaming",
    "ai"
  ],
  "server": {
    "type": "python",
    "entry_point": "server/launch.py",
    "mcp_config": {
      "command": "python",
      "args": ["${__dirname}/server/launch.py"],
      "env": {
        "PYTHONPATH": "${__dirname}/server"
      }
    }
  },
  "tools": [
    { "name": "analyze_character" },
    { "name": "compare_to_top_players" },
    { "name": "validate_support_combination" },
    { "name": "validate_build_constraints" },
    { "name": "inspect_support_gem" },
    { "name": "inspect_spell_gem" },
    { "name": "list_all_supports" },
    { "name": "list_all_spells" },
    { "name": "list_all_keystones" },
    { "name": "inspect_keystone" },
    { "name": "list_all_mods" },
    { "name": "inspect_mod" },
    { "name": "explain_mechanic" },
    { "name": "get_formula" },
    { "name": "import_pob" },
    { "name": "export_pob" }
  ]
}
